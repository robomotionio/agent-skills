# Phase 3 (live-data verification) credentials.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
#
# Connect a deskbot worker once with:
#   robomotion-deskbot connect \
#     -i $ROBOMOTION_USER_EMAIL \
#     -w $ROBOMOTION_WORKSPACE \
#     -r $ROBOMOTION_ROBOT_ID \
#     -t $ROBOMOTION_ROBOT_TOKEN
#
# Then `bun run evals:verify` runs each Phase 2-generated flow on that robot
# and compares the produced CSV against the eval's assertions.

ROBOMOTION_USER_EMAIL=you@example.com
ROBOMOTION_WORKSPACE=demo.robomotion.io
ROBOMOTION_ROBOT_ID=00000000-0000-0000-0000-000000000000
ROBOMOTION_ROBOT_TOKEN=replace-with-real-robot-token
ROBOMOTION_API_KEY=replace-with-real-api-key
